NODE_ENV=development
PORT=3000
PERSISTENCE_MODE=memory
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meshva_hospitality
DB_POOL_MAX=10
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me
NPM_REGISTRY_URL=https://npm.meshva.internal/
